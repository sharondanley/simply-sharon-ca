{
  "name": "simply-sharon",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "mkdir -p dist && cp index.html dist/index.html",
    "start": "node -e \"const h=require('http'),fs=require('fs');h.createServer((q,r)=>{r.writeHead(200,{'Content-Type':'text/html'});r.end(fs.readFileSync('dist/index.html'))}).listen(process.env.PORT||3000)\""
  }
}
